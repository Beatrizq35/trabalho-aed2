#include <stdio.h>
#include <stdlib.h>
#include <time.h>
#include <math.h>
 
#define TAM 20
#define EXECUCOES 30
 
// 1. Criar vetor do tipo inteiro desordenado
void criaVetDesordenado(int vet[], int tam) {
    for (int i = 0; i < tam; i++) {
        vet[i] = rand() % (TAM * 10); // valores entre 0 e 199
    }
}
 
// 2. Criar vetor do tipo inteiro ordenado
void criaVetOrdenado(int vet[], int tam) {
    int atual = rand() % 10;
    for (int i = 0; i < tam; i++) {
        vet[i] = atual;
        atual += (rand() % 5) + 1;
    }
}
 
// 3. Busca Sequencial
int buscaSequencial(int vet[], int key) {
    for (int i = 0; i < TAM; i++) {
        if (key == vet[i]) {
            return 1;
        }
    }
    return 0;
}
 
// 4. Busca Binária
int buscaBinaria(int vet[], int key) {
    int inicio = 0, fim = TAM - 1;
    while (inicio <= fim) {
        int meio = (inicio + fim) / 2;
        if (key > vet[meio]) {
            inicio = meio + 1;
        } else if (key < vet[meio]) {
            fim = meio - 1;
        } else {
            return 1;
        }
    }
    return 0;
}
 
// 5. Calcular tempo de execução
double calculaTempo(struct timespec inicio, struct timespec fim) {
    return (fim.tv_sec - inicio.tv_sec) +
           (fim.tv_nsec - inicio.tv_nsec) / 1e9;
}
 
// 6. Calcular média
double calculaMedia(double tempos[], int n) {
    double soma = 0.0;
    for (int i = 0; i < n; i++) soma += tempos[i];
    return soma / n;
}
 
// 7. Calcular desvio padrão
double desvioPadrao(double tempos[], int n) {
    double media = calculaMedia(tempos, n);
    double soma = 0.0;
    for (int i = 0; i < n; i++) {
        double diff = tempos[i] - media;
        soma += diff * diff;
    }
    return sqrt(soma / n);
}
 
// Utilitário: imprime o vetor
void imprimeVetor(int vet[], int tam) {
    printf("[ ");
    for (int i = 0; i < tam; i++) {
        printf("%d", vet[i]);
        if (i < tam - 1) printf(", ");
    }
    printf(" ]\n");
}
 
int main() {
    srand(time(NULL));
 
    int v_desordenado[TAM];
    int v_ordenado[TAM];
 
    criaVetDesordenado(v_desordenado, TAM);
    criaVetOrdenado(v_ordenado, TAM);
 
    printf("==============================================\n");
    printf("  VETOR DESORDENADO (usado na busca sequencial):\n");
    printf("  ");
    imprimeVetor(v_desordenado, TAM);
    printf("\n");
    printf("  VETOR ORDENADO (usado na busca binaria):\n");
    printf("  ");
    imprimeVetor(v_ordenado, TAM);
    printf("==============================================\n\n");
 
    double tempos_seq[EXECUCOES];
    double tempos_bin[EXECUCOES];
 
    // -------------------------------------------------------
    // BUSCA SEQUENCIAL
    // -------------------------------------------------------
    printf("##############################################\n");
    printf("         BUSCA SEQUENCIAL (30 execucoes)\n");
    printf("##############################################\n\n");
 
    for (int i = 0; i < EXECUCOES; i++) {
        struct timespec inicio, fim;
        int chave;
 
        // 15 primeiras: chave garantida no vetor
        if (i < 15) {
            int pos = rand() % TAM;
            chave = v_desordenado[pos];
        } else {
            chave = rand() % (TAM * 10);
        }
 
        clock_gettime(CLOCK_MONOTONIC, &inicio);
        int encontrado = buscaSequencial(v_desordenado, chave);
        clock_gettime(CLOCK_MONOTONIC, &fim);
        tempos_seq[i] = calculaTempo(inicio, fim);
 
        printf("----------------------------------------------\n");
        printf("Execucao %2d | Tipo: %s\n",
               i + 1,
               i < 15 ? "GARANTIDA (chave existe)" : "ALEATORIA (pode nao existir)");
        printf("Vetor: ");
        imprimeVetor(v_desordenado, TAM);
        printf("Chave buscada : %d\n", chave);
        printf("Resultado     : %s\n", encontrado ? "ENCONTRADA ✓" : "NAO ENCONTRADA ✗");
        printf("Tempo         : %.9f segundos\n", tempos_seq[i]);
 
        // Métricas acumuladas até esta execução
        double media_parcial  = calculaMedia(tempos_seq, i + 1);
        double desvio_parcial = desvioPadrao(tempos_seq, i + 1);
        printf("Media parcial : %.9f segundos\n", media_parcial);
        printf("Desvio parcial: %.9f segundos\n", desvio_parcial);
        printf("\n");
    }
 
    double media_seq  = calculaMedia(tempos_seq, EXECUCOES);
    double desvio_seq = desvioPadrao(tempos_seq, EXECUCOES);
 
    printf("==============================================\n");
    printf("  RESULTADO FINAL - BUSCA SEQUENCIAL\n");
    printf("  Media      : %.9f segundos\n", media_seq);
    printf("  Desvio Pad.: %.9f segundos\n", desvio_seq);
    printf("==============================================\n\n");
 
    // -------------------------------------------------------
    // BUSCA BINÁRIA
    // -------------------------------------------------------
    printf("##############################################\n");
    printf("           BUSCA BINARIA (30 execucoes)\n");
    printf("##############################################\n\n");
 
    for (int i = 0; i < EXECUCOES; i++) {
        struct timespec inicio, fim;
        int chave;
 
        if (i < 15) {
            int pos = rand() % TAM;
            chave = v_ordenado[pos];
        } else {
            chave = rand() % (TAM * 10);
        }
 
        clock_gettime(CLOCK_MONOTONIC, &inicio);
        int encontrado = buscaBinaria(v_ordenado, chave);
        clock_gettime(CLOCK_MONOTONIC, &fim);
        tempos_bin[i] = calculaTempo(inicio, fim);
 
        printf("----------------------------------------------\n");
        printf("Execucao %2d | Tipo: %s\n",
               i + 1,
               i < 15 ? "GARANTIDA (chave existe)" : "ALEATORIA (pode nao existir)");
        printf("Vetor: ");
        imprimeVetor(v_ordenado, TAM);
        printf("Chave buscada : %d\n", chave);
        printf("Resultado     : %s\n", encontrado ? "ENCONTRADA ✓" : "NAO ENCONTRADA ✗");
        printf("Tempo         : %.9f segundos\n", tempos_bin[i]);
 
        double media_parcial  = calculaMedia(tempos_bin, i + 1);
        double desvio_parcial = desvioPadrao(tempos_bin, i + 1);
        printf("Media parcial : %.9f segundos\n", media_parcial);
        printf("Desvio parcial: %.9f segundos\n", desvio_parcial);
        printf("\n");
    }
 
    double media_bin  = calculaMedia(tempos_bin, EXECUCOES);
    double desvio_bin = desvioPadrao(tempos_bin, EXECUCOES);
 
    printf("==============================================\n");
    printf("  RESULTADO FINAL - BUSCA BINARIA\n");
    printf("  Media      : %.9f segundos\n", media_bin);
    printf("  Desvio Pad.: %.9f segundos\n", desvio_bin);
    printf("==============================================\n\n");
 
    // -------------------------------------------------------
    // TABELA COMPARATIVA FINAL
    // -------------------------------------------------------
    printf("==============================================\n");
    printf("         TABELA COMPARATIVA FINAL\n");
    printf("==============================================\n");
    printf("%-20s | %-15s | %-15s\n", "ALGORITMO", "MEDIA (s)", "DESVIO PADRAO");
    printf("----------------------------------------------\n");
    printf("%-20s | %-15.9f | %-15.9f\n", "Busca Sequencial", media_seq, desvio_seq);
    printf("%-20s | %-15.9f | %-15.9f\n", "Busca Binaria",    media_bin, desvio_bin);
    printf("==============================================\n");
 
    return 0;
}
